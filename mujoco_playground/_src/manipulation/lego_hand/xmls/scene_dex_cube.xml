<mujoco model="lego_hand_scene">
  <include file="lego_hand.xml"/>
  <include file="reorientation_cube.xml"/>

  <statistic center="0.06 0 0.05" extent="0.4" meansize="0.01"/>

  <visual>
    <headlight diffuse=".8 .8 .8" ambient=".2 .2 .2" specular="1 1 1"/>
    <rgba force="1 0 0 1"/>
    <global azimuth="120" elevation="-20"/>
    <map force="0.01" stiffness="500"/>
    <scale forcewidth="0.1" contactwidth="0.5" contactheight="0.2"/>
    <quality shadowsize="8192"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="1 1 1" rgb2="1 1 1" width="800" height="800"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="1 1 1" rgb2="1 1 1"
      markrgb="0 0 0" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0"/>
  </asset>

  <worldbody>
    <camera name="side" pos="-0.2 0.45 0.35" xyaxes="-0.85 -0.53 0.00 0.30 -0.45 0.84"/>
    <geom name="floor" pos="0 0 -0.1" size="0 0 0.01" type="plane" material="groundplane"
      contype="2" conaffinity="2"/>
    <!-- goal: mocap body showing target cube orientation -->
    <body name="goal" mocap="true" pos="0.2 0.1 0.12">
      <geom type="mesh" mesh="cube_mesh" material="dexcube" contype="0" conaffinity="0" density="0" group="2"/>
      <geom type="box" size=".035 .035 .035" mass=".108" contype="0" conaffinity="0"
        group="3" rgba="0.8 0.8 0.8 0.4"/>
    </body>
  </worldbody>

  <sensor>
    <!-- cube -->
    <framepos  name="cube_position"    objtype="body" objname="cube"/>
    <framequat name="cube_orientation" objtype="body" objname="cube"/>
    <framelinvel name="cube_linvel"    objtype="body" objname="cube"/>
    <frameangvel name="cube_angvel"    objtype="body" objname="cube"/>
    <frameangacc name="cube_angacc"    objtype="body" objname="cube"/>
    <framezaxis  name="cube_upvector"  objtype="body" objname="cube"/>

    <!-- hand -->
    <framepos name="palm_position"  objtype="site" objname="grasp_site"/>
    <framepos name="f1_tip_position" objtype="site" objname="f1_tip" reftype="site" refname="grasp_site"/>
    <framepos name="f2_tip_position" objtype="site" objname="f2_tip" reftype="site" refname="grasp_site"/>
    <framepos name="f3_tip_position" objtype="site" objname="f3_tip" reftype="site" refname="grasp_site"/>
    <framepos name="f4_tip_position" objtype="site" objname="f4_tip" reftype="site" refname="grasp_site"/>
    <framepos name="f5_tip_position" objtype="site" objname="f5_tip" reftype="site" refname="grasp_site"/>

    <!-- goal -->
    <framequat name="cube_goal_orientation" objtype="body" objname="goal"/>
    <framezaxis name="cube_goal_upvector"   objtype="body" objname="goal"/>
  </sensor>

  <keyframe>
    <!-- hand: 5 fingers × 4 joints = 20 values (palm=0, base=0.5, mid=0.5, end=0.5)
         cube freejoint: 3 pos + 4 quat = 7 values
         Total qpos = 27 -->
    <key name="home"
      qpos="
      0 0.5 0.5 0.5
      0 0.5 0.5 0.5
      0 0.5 0.5 0.5
      0 0.5 0.5 0.5
      0 0.5 0.5 0.5
      0.04 0.001 0.12 1 0 0 0"
      ctrl="
      0 0.5 0.5 0.5
      0 0.5 0.5 0.5
      0 0.5 0.5 0.5
      0 0.5 0.5 0.5
      0 0.5 0.5 0.5"
      mpos="0.2 0.1 0.12"
      mquat="1 0 0 0"/>
  </keyframe>

</mujoco>
