        <joint name="f1_finger_palm_joint"   class="palm_joint"/>
        <geom class="visual" pos="-0.01863 -0.06172 0.028" mesh="finger_base_servo_part0"/>
        <geom name="f1_bs_col" type="box" size="0.009 0.008 0.012" pos="0 0.005 0"/>
        <body name="f1_finger_base_lever" pos="0.01709 0.00043 -0.00464">
          <inertial pos="0 0 0" mass="0.025" diaginertia="2.5e-05 2.5e-05 2.5e-05"/>
          <joint name="f1_finger_base_joint" class="base_joint"/>
          <geom class="visual" pos="-0.03572 -0.06215 0.03264" mesh="finger_base_lever_part0"/>
          <geom class="visual" pos="-0.03572 -0.06215 0.03264" mesh="finger_grammar1_part0"/>
          <geom class="visual" pos="-0.03572 -0.06215 0.03264" mesh="finger_middle_servo_part0"/>
