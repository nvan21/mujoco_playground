            <geom class="visual" pos="-0.03457 -0.09362 0.03378" mesh="finger_grammar2_part0"/>
            <geom class="visual" pos="-0.03457 -0.09362 0.03378" mesh="finger_end_servo_part0"/>
            <geom name="f1_ml_col" type="box" size="0.009 0.015 0.009" pos="0 0.015 0"/>
            <body name="f1_finger_end_lever" pos="-0.00104 0.03148 -0.001">
              <inertial pos="0 0 0" mass="0.015" diaginertia="1.1e-05 1.1e-05 1.1e-05"/>
              <joint name="f1_finger_end_joint" class="end_joint"/>
              <geom class="visual" pos="-0.03353 -0.1251 0.03478" mesh="finger_end_lever_part0"/>
              <geom class="visual" pos="-0.03353 -0.1251 0.03478" mesh="finger_tip_part0"/>
              <geom name="f1_tip" class="tip" pos="0 0.025 0"/>
              <site name="f1_tip" pos="0 0.035 0" group="4"/>
            </body>
          </body>
        </body>
      </body>

